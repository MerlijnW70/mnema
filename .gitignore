/target
Cargo.lock

# Engram stores are encrypted, machine-specific data — never source.
*.engram

# Per-store key: the random secret that seals the sibling *.engram. NEVER source.
*.key

# Project-scoped MCP config: machine-specific store path. Keep out of source control.
.mcp.json

# noha (the emerge audit engine): project-local binaries + cargo-install metadata are a
# local install, not source. Recreate them with:
#   cargo install --path <emerge>/core --root .noha --force
# The *policy* — noha.yaml and the ratchet baseline .noha/baseline.tsv — IS tracked; it
# is what makes a green build mean something.
/.noha/bin/
/.noha/.crates.toml
/.noha/.crates2.json
# TIA is a learned local cache (regenerated on demand); the baseline is the source of truth.
/.noha/tia.tsv
